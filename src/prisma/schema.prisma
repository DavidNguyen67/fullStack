// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  email      String   @unique
  password   String
  name       String
  address    String?
  phone      String?
  gender     String
  typeId     String
  positionId String
  avatar     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @default(now())
}
model AllCode {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  value_en  String
  value_vi  String
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}
model Bookings {
  id        Int      @id @default(autoincrement())
  statusId  Int      
  doctorId  Int
  patientId Int
  date      DateTime @db.DateTime() 
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}
model Histories {
  id        Int      @id @default(autoincrement())
  patientId Int
  doctorId  Int
  des       String?
  file      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}
model Clinics {
  id        Int      @id @default(autoincrement())
  name      String 
  address   String
  des       String?
  img       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}
model Schedule {
  id            Int      @id @default(autoincrement())
  currentNumber Int
  maxNumber     Int
  date          DateTime @db.DateTime()
  doctorId      Int
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}
model Specialties {
  id        Int      @id @default(autoincrement())
  des       String?
  img       String?
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}
model Doctor_Clinic_Specialties {
  id           Int     @id @default(autoincrement())
  doctorId     Int
  clinicId     Int
  specialtyId  Int
  createdAt DateTime @default(now())
  updatedAt DateTime @default(now())
}